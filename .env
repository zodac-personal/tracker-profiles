# Chrome Browser
SE_VNC_NO_PASSWORD=1
SE_OPTS=--log-level WARNING
# Java App
DISPLAY=:99
PUID=1000
PGID=1000
BROWSER_HEIGHT=1050
BROWSER_WIDTH=1680
CSV_COMMENT_SYMBOL=#
ENABLE_ADULT_TRACKERS=true
ENABLE_TRANSLATION_TO_ENGLISH=true
FORCE_UI_BROWSER=false
INPUT_TIMEOUT_ENABLED=false
INPUT_TIMEOUT_SECONDS=300
LOG_LEVEL=INFO
NUMBER_OF_TRACKER_ATTEMPTS=1
OUTPUT_DIRECTORY_NAME_FORMAT=yyyy-MM-dd
OUTPUT_DIRECTORY_PARENT_PATH=/app/screenshots
REDACTION_TYPE=BOX
SCREENSHOT_EXISTS_ACTION=CREATE_ANOTHER
SELENIUM_REMOTE_URL=http://tracker-profiles-chrome:4444
TAKE_SCREENSHOT_ON_ERROR=false
TIMEZONE=UTC
TRACKER_EXECUTION_ORDER=HEADLESS,MANUAL
TRACKER_INPUT_FILE_PATH=/app/screenshots/trackers.csv
VNC_SIGNAL_FILE_PATH=/run/vnc-signal
